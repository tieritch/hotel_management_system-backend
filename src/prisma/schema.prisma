datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}


model User {
  id                String       @id @default(uuid())
  username          String       @unique
  password_hash     String
  created_at        DateTime     @default(now())
  is_active         Boolean      @default(false)
  updated_at        DateTime     @updatedAt
  bookingsCreated  Booking[]   @relation("BookingCreatedBy")
  bookingsUpdated  Booking[]   @relation("BookingUpdatedBy")
  customersCreated Customer[]  @relation("CustomerCreatedBy")
  customersUpdated Customer[]  @relation("CustomerUpdatedBy")
  employee          Employee?
  staysCreated     Stay[]      @relation("StayCreatedBy")
  staysUpdated     Stay[]      @relation("StayUpdatedBy")
  userRoles        UserRole[]
   @@map("users")
 
}

model Role{
  id               String             @id @default(uuid())
  name        String             @unique
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  rolePermissions RolePermission[]
  userRoles       UserRole[]
   @@map("roles")
}

model UserRole {
  user_id     String
  role_id     String
  assigned_at DateTime  @default(now())
  revoked_at  DateTime?
  role        Role     @relation(fields: [role_id], references: [id])
  user        User     @relation(fields: [user_id], references: [id])
  @@id([user_id, role_id])
   @@map("user_roles")
}

model Resource {
  id            Int        @id @default(autoincrement())
  name String        @unique
  permissions   Permission[]
   @@map("resources")
}

model Action {
  id          Int        @id @default(autoincrement())
  name String        @unique
  permissions Permission[]
   @@map("actions")
}

model Permission {
  id               String             @id @default(uuid())
  action_id        Int
  resource_id      Int
  action           Action            @relation(fields: [action_id], references: [id])
  resource         Resource          @relation(fields: [resource_id], references: [id])
  rolePermission RolePermission[]

  @@unique([resource_id, action_id])
   @@map("permissions")
}

model RolePermission {
  role_id       String
  permission_id String
  permission    Permission @relation(fields: [permission_id], references: [id])
  role          Role      @relation(fields: [role_id], references: [id])

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model Position {
  id            Int      @id @default(autoincrement())
  name String      @unique
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  employees     Employee[]
  @@map("positions")
}

model Employee {
  id             String               @id @default(uuid())
  first_name     String
  last_name      String
  email          String               @unique
  created_at     DateTime             @default(now())
  hire_date      DateTime?
  phone_number      String?
  position_id    Int
  updated_at     DateTime             @updatedAt
  user_id        String?              @unique
  position       Position            @relation(fields: [position_id], references: [id])
  user           User?               @relation(fields: [user_id], references: [id])
  schedules      EmployeeSchedule[]
  roomCleanings RoomCleaning[]

  @@index([position_id])
  @@map("employees")
}

model EmployeeSchedule {
  id          String    @id @default(uuid())
  employee_id String
  start_time  DateTime
  end_time    DateTime
  employee    Employee @relation(fields: [employee_id], references: [id])

  @@index([employee_id])
  @@map("employee_schedules")
}

model Customer {
  id         String     @id @default(uuid())
  first_name String
  last_name  String
  email      String?
  created_at DateTime   @default(now())
  created_by String?
  phone_number  String?
  updated_at DateTime   @updatedAt
  updated_by String?
  bookings   Booking[]
  creator    User?     @relation("CustomerCreatedBy", fields: [created_by], references: [id])
  updater    User?     @relation("CustomerUpdatedBy", fields: [updated_by], references: [id])
  orders     Order[]
  stays      Stay[]

  @@index([email])
  @@map("customers")
}

model Booking {
  id                 String    @id @default(uuid())
  customer_id        String
  created_at         DateTime  @default(now())
  created_by         String?
  expected_check_in  DateTime
  expected_check_out DateTime
  notes              String?
  room_id            String
  status             String
  updated_at         DateTime  @updatedAt
  updated_by         String?
  creator            User?    @relation("BookingCreatedBy", fields: [created_by], references: [id])
  customer           Customer @relation(fields: [customer_id], references: [id])
  room               Room     @relation(fields: [room_id], references: [id])
  updater            User?    @relation("BookingUpdatedBy", fields: [updated_by], references: [id])
  stay               Stay?

  @@index([customer_id])
  @@index([room_id])
  @@index([status])
  @@map("bookings")
}

model RoomType {
  id          Int   @id @default(autoincrement())
  name   String   @unique
  base_price  Decimal  @db.Decimal(12, 2)
  created_at  DateTime @default(now())
  description String?
  updated_at  DateTime @updatedAt
  rooms       Room[]
  @@map("room_types")
}

model RoomStatus {
  id          Int      @id @default(autoincrement())
  name        String   @unique // Ex: "AVAILABLE", "OCCUPIED", "CLEANING", "MAINTENANCE"
  description String?  // Pour expliquer à quoi sert ce statut
  rooms       Room[]

  @@map("room_statuses")
}


model Room {
  id             String           @id @default(uuid())
  room_type_id   Int
  room_number    Int           @unique
  room_name      String        @unique 
  created_at     DateTime         @default(now())
  room_status_id Int?
  updated_at     DateTime         @updatedAt
  bookings       Booking[]
  roomType      RoomType       @relation(fields: [room_type_id], references: [id])
  roomStatus    RoomStatus?    @relation(fields: [room_status_id], references: [id]) 
  roomCleanings RoomCleaning[]
  stays          Stay[]

  @@index([room_type_id])
  @@index([room_status_id])
  @@map("rooms")
}

model Stay {
  id          String     @id @default(uuid())
  booking_id  String     @unique
  customer_id String
  check_in    DateTime
  check_out   DateTime?
  created_at  DateTime   @default(now())
  created_by  String?
  room_id     String
  updated_at  DateTime   @updatedAt
  updated_by  String?
  invoices    Invoice[]
  booking     Booking   @relation(fields: [booking_id], references: [id])
  creator     User?     @relation("StayCreatedBy", fields: [created_by], references: [id])
  customer    Customer  @relation(fields: [customer_id], references: [id])
  room        Room      @relation(fields: [room_id], references: [id])
  updater     User?     @relation("StayUpdatedBy", fields: [updated_by], references: [id])

  @@index([customer_id])
  @@index([room_id])
  @@map("stays")
}

model RoomCleaning {
  id          String    @id @default(uuid())
  room_id     String
  employee_id String
  cleaned_at  DateTime  @default(now())
  notes       String?
  employee    Employee @relation(fields: [employee_id], references: [id])
  room        Room     @relation(fields: [room_id], references: [id])

  @@index([room_id])
  @@index([employee_id])
  @@map("room_cleanings")
}

model MenuItem {
  id           String        @id @default(uuid())
  name    String
  created_at   DateTime      @default(now())
  is_available Boolean       @default(true)
  price        Decimal       @db.Decimal(12, 2)
  measuring_unit_id Int 
  measuring_unit MeasuringUnit @relation(fields:[measuring_unit_id], references:[id])
  updated_at   DateTime      @updatedAt
  orderItems  OrderItem[]
  @@map("menu_items")
}

model Order {
  id           String        @id @default(uuid())
  customer_id  String
  order_date   DateTime      @default(now())
  status       String
  total_amount Decimal       @db.Decimal(12, 2)
  customer     Customer     @relation(fields: [customer_id], references: [id])
  orderItems  OrderItem[]
  @@map("orders")
}

model OrderItem {
  id           String     @id @default(uuid())
  order_id     String
  menu_item_id String
  quantity     Int
  unit_price   Decimal    @db.Decimal(12, 2)
  menu_item    MenuItem @relation(fields: [menu_item_id], references: [id])
  order        Order     @relation(fields: [order_id], references: [id])

  @@index([order_id])
  @@index([menu_item_id])
  @@map("order_items")
}

model Invoice {
  id           String         @id @default(uuid())
  stay_id      String
  total_amount Decimal        @db.Decimal(12, 2)
  invoice_date DateTime       @default(now())
  stay         Stay          @relation(fields: [stay_id], references: [id])
  transactions Transaction[]

  @@index([stay_id])
  @@map("invoices")

}

model Transaction {
  id             String   @id @default(uuid())
  invoice_id     String
  amount         Decimal  @db.Decimal(12, 2)
  payment_method String
  payment_date   DateTime @default(now())
  invoice        Invoice @relation(fields: [invoice_id], references: [id])

  @@index([invoice_id])
  @@map("transactions")
}

model MeasuringUnit {
  id   Int @id @default(autoincrement())
  name String  @unique
  description String
  menuItems  MenuItem[]
  @@map("measuring_units")
 }
