datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==================================================
// USERS, ROLES & PERMISSIONS
// ==================================================

model User {
  id               String       @id @default(uuid())
  username         String       @unique
  passwordHash     String       @map("password_hash")
  createdAt        DateTime     @default(now()) @map("created_at")
  isActive         Boolean      @default(false) @map("is_active")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  
  bookingsCreated  Booking[]    @relation("BookingCreatedBy")
  bookingsUpdated  Booking[]    @relation("BookingUpdatedBy")
  customersCreated Customer[]   @relation("CustomerCreatedBy")
  customersUpdated Customer[]   @relation("CustomerUpdatedBy")
  employee         Employee?
  staysCreated     Stay[]       @relation("StayCreatedBy")
  staysUpdated     Stay[]       @relation("StayUpdatedBy")
  userRoles        UserRole[]
  
  @@map("users")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  
  rolePermissions RolePermission[]
  userRoles       UserRole[]
  
  @@map("roles")
}

model UserRole {
  userId     String    @map("user_id")
  roleId     String    @map("role_id")
  assignedAt DateTime  @default(now()) @map("assigned_at")
  revokedAt  DateTime? @map("revoked_at")
  
  role       Role      @relation(fields: [roleId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
  
  @@id([userId, roleId])
  @@map("user_roles")
}

model Resource {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  permissions Permission[]
  
  @@map("resources")
}

model Action {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  permissions Permission[]
  
  @@map("actions")
}

model Permission {
  id             String           @id @default(uuid())
  actionId       Int              @map("action_id")
  resourceId     Int              @map("resource_id")
  
  action         Action           @relation(fields: [actionId], references: [id])
  resource       Resource         @relation(fields: [resourceId], references: [id])
  rolePermission RolePermission[]

  @@unique([resourceId, actionId])
  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ==================================================
// EMPLOYEES & MANAGEMENT
// ==================================================

model Position {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  employees Employee[]
  
  @@map("positions")
}

model Employee {
  id             String             @id @default(uuid())
  firstname      String             @map("first_name")
  lastname       String             @map("last_name")
  email          String             @unique
  createdAt      DateTime           @default(now()) @map("created_at")
  hireDate       DateTime?          @map("hire_date")
  phoneNumber    String?            @map("phone_number")
  positionId     Int                @map("position_id")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  userId         String?            @unique @map("user_id")
  
  position       Position           @relation(fields: [positionId], references: [id])
  user           User?              @relation(fields: [userId], references: [id])
  schedules      EmployeeSchedule[]
  roomCleanings  RoomCleaning[]

  @@index([positionId])
  @@map("employees")
}

model EmployeeSchedule {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  startTime  DateTime @map("start_time")
  endTime    DateTime @map("end_time")
  
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("employee_schedules")
}

// ==================================================
// HÔTEL: ROOMS, BOOKINGS & STAYS
// ==================================================

model RoomType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  basePrice   Decimal  @db.Decimal(12, 2) @map("base_price")
  createdAt   DateTime @default(now()) @map("created_at")
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  rooms       Room[]
  
  @@map("room_types")
}

model RoomStatus {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  
  rooms       Room[]

  @@map("room_statuses")
}

model Room {
  id           String   @id @default(uuid())
  roomTypeId   Int      @map("room_type_id")
  roomNumber   Int      @unique @map("room_number")
  roomName     String   @unique @map("room_name")
  createdAt    DateTime @default(now()) @map("created_at")
  roomStatusId Int?     @map("room_status_id")
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  bookings     Booking[]
  roomType     RoomType @relation(fields: [roomTypeId], references: [id])
  roomStatus   RoomStatus? @relation(fields: [roomStatusId], references: [id]) 
  roomCleanings RoomCleaning[]
  stays        Stay[]

  @@index([roomTypeId])
  @@index([roomStatusId])
  @@map("rooms")
}

model Customer {
  id          String     @id @default(uuid())
  firstName   String     @map("first_name")
  lastName    String     @map("last_name")
  email       String?    @unique
  createdAt   DateTime   @default(now()) @map("created_at")
  createdBy   String?    @map("created_by")
  phoneNumber String?    @map("phone_number")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  updatedBy   String?    @map("updated_by")
  
  bookings    Booking[]
  creator     User?      @relation("CustomerCreatedBy", fields: [createdBy], references: [id])
  updater     User?      @relation("CustomerUpdatedBy", fields: [updatedBy], references: [id])
  orders      Order[]
  stays       Stay[]

  @@index([email])
  @@map("customers")
}

model Booking {
  id               String   @id @default(uuid())
  customerId       String   @map("customer_id")
  createdAt        DateTime @default(now()) @map("created_at")
  createdBy        String?  @map("created_by")
  expectedCheckIn  DateTime @map("expected_check_in")
  expectedCheckOut DateTime @map("expected_check_out")
  notes            String?
  roomId           String   @map("room_id")
  status           String
  updatedAt        DateTime @updatedAt @map("updated_at")
  updatedBy        String?  @map("updated_by")
  
  creator          User?    @relation("BookingCreatedBy", fields: [createdBy], references: [id])
  customer         Customer @relation(fields: [customerId], references: [id])
  room             Room     @relation(fields: [roomId], references: [id])
  updater          User?    @relation("BookingUpdatedBy", fields: [updatedBy], references: [id])
  stay             Stay?

  @@index([customerId])
  @@index([roomId])
  @@index([status])
  @@map("bookings")
}

model Stay {
  id         String    @id @default(uuid())
  bookingId  String    @unique @map("booking_id")
  customerId String    @map("customer_id")
  checkIn    DateTime  @map("check_in")
  checkOut   DateTime? @map("check_out")
  createdAt  DateTime  @default(now()) @map("created_at")
  createdBy  String?   @map("created_by")
  roomId     String    @map("room_id")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  updatedBy  String?   @map("updated_by")
  
  invoices   Invoice[]
  booking    Booking   @relation(fields: [bookingId], references: [id])
  creator    User?     @relation("StayCreatedBy", fields: [createdBy], references: [id])
  customer   Customer  @relation(fields: [customerId], references: [id])
  room       Room      @relation(fields: [roomId], references: [id])
  updater    User?     @relation("StayUpdatedBy", fields: [updatedBy], references: [id])

  @@index([customerId])
  @@index([roomId])
  @@map("stays")
}

model RoomCleaning {
  id         String   @id @default(uuid())
  roomId     String   @map("room_id")
  employeeId String   @map("employee_id")
  cleanedAt  DateTime @default(now()) @map("cleaned_at")
  notes      String?
  
  employee   Employee @relation(fields: [employeeId], references: [id])
  room       Room     @relation(fields: [roomId], references: [id])

  @@index([roomId])
  @@index([employeeId])
  @@map("room_cleanings")
}

// ==================================================
// RESTAURANT & ORDERS
// ==================================================

model MenuItem {
  id              String        @id @default(uuid())
  name            String
  createdAt       DateTime      @default(now()) @map("created_at")
  isAvailable     Boolean       @default(true) @map("is_available")
  price           Decimal       @db.Decimal(12, 2)
  measuringUnitId Int           @map("measuring_unit_id")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  
  measuringUnit   MeasuringUnit @relation(fields: [measuringUnitId], references: [id])
  orderItems      OrderItem[]
  
  @@map("menu_items")
}

model Order {
  id          String      @id @default(uuid())
  customerId  String      @map("customer_id")
  orderDate   DateTime    @default(now()) @map("order_date")
  status      String
  totalAmount Decimal     @db.Decimal(12, 2) @map("total_amount")
  
  customer    Customer    @relation(fields: [customerId], references: [id])
  orderItems  OrderItem[]
  
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  menuItemId String   @map("menu_item_id")
  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2) @map("unit_price")

  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

// ==================================================
// INVOICES & TRANSACTIONS
// ==================================================

model Invoice {
  id          String        @id @default(uuid())
  stayId      String        @map("stay_id")
  totalAmount Decimal       @db.Decimal(12, 2) @map("total_amount")
  invoiceDate DateTime      @default(now()) @map("invoice_date")

  stay        Stay          @relation(fields: [stayId], references: [id])
  transactions Transaction[]

  @@index([stayId])
  @@map("invoices")
}

model Transaction {
  id            String   @id @default(uuid())
  invoiceId     String   @map("invoice_id")
  amount        Decimal  @db.Decimal(12, 2)
  paymentMethod String   @map("payment_method")
  paymentDate   DateTime @default(now()) @map("payment_date")

  invoice       Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("transactions")
}

// ==================================================
// INVENTORY & STOCK MANAGEMENT
// ==================================================
model MeasuringUnit {
  id               Int             @id @default(autoincrement())
  name             String          @unique // Ex: "bottle_juice_65cl", "pack_sugar_1kg", "cl", "g"
  description      String          // Ex: "Bouteille de jus (65 cl)", "Gramme"
  
  // CORRECTION : Vos deux colonnes de conversion simples, sans aucune liaison complexe
  convertTo        String?         @map("convert_to")         // Ex: "cl" ou "g" (Optionnel)
  conversionFactor Decimal         @db.Decimal(12, 2) @default(1.00) @map("conversion_factor") // Ex: 65.00 ou 1000.00

  // Liens standards avec le reste de votre application
  menuItems        MenuItem[]
  purchaseItemUnits InventoryItem[] @relation("PurchaseUnitRelation")
  retailItemUnits   InventoryItem[] @relation("RetailUnitRelation")
  
  @@map("measuring_units")
}

model InventoryItem {
  id              String            @id @default(uuid())
  name            String            @unique
  currentStock    Decimal           @db.Decimal(12, 2) @default(0.00) @map("current_stock")
  minStockLevel   Decimal?          @db.Decimal(12, 2) @map("min_stock_level")
  unitCost        Decimal           @db.Decimal(12, 2) @default(0.00) @map("unit_cost")
  retailPrice     Decimal?          @db.Decimal(12, 2) @map("retail_price")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  purchaseUnitId  Int               @map("purchase_unit_id")
  retailUnitId    Int               @map("retail_unit_id")

  purchaseUnit    MeasuringUnit     @relation("PurchaseUnitRelation", fields: [purchaseUnitId], references: [id])
  retailUnit      MeasuringUnit     @relation("RetailUnitRelation", fields: [retailUnitId], references: [id])
  
  movements       StockMovement[]
  purchaseItems   PurchaseOrderItem[]

  @@index([purchaseUnitId])
  @@index([retailUnitId])
  @@map("inventory_items")
}

enum MovementType {
  IN
  OUT
  LOSS
  ADJUSTMENT
}

model StockMovement {
  id             String        @id @default(uuid())
  inventoryItemId String       @map("inventory_item_id")
  quantity       Decimal       @db.Decimal(12, 2)
  type           MovementType
  reason         String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  inventoryItem  InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([inventoryItemId])
  @@map("stock_movements")
}

enum OrderStatus {
  PENDING
  DELIVERED
  REJECTED
}

model PurchaseOrder {
  id           String            @id @default(uuid())
  orderNumber  String            @unique @map("order_number")
  status       OrderStatus       @default(PENDING)
  supplier_id  String 
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  items        PurchaseOrderItem[]
  supplier     Supplier @relation(fields:[supplier_id], references:[id] )

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String        @map("purchase_order_id")
  inventoryItemId String        @map("inventory_item_id")
  quantity        Decimal       @db.Decimal(12, 2)
  unitCost        Decimal       @db.Decimal(12, 2) @map("unit_cost")

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
  @@map("purchase_order_items")
}

model Supplier {
  id               String      @id @default(uuid())
  firstname        String
  lastname         String?
  address          String?
  phoneNumber      String      @unique @map("phone_number")
  email            String?     @unique
  purchaseOrders  PurchaseOrder[]
  @@map("suppliers")
}