{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "set NODE_ENV = development && nodemon src",
    "prod": "set NODE_ENV= production && node src",
    "lint": "eslint .",
    "format": "prettier --write",
    "lint:fix": "eslint . --fix",
    "db:migrate": "prisma migrate dev --name init_complete  --schema src/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema src/prisma/schema.prisma",
    "db:push": "prisma db push --schema src/prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema src/prisma/schema.prisma",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:gen": "prisma generate  --schema src/prisma/schema.prisma",
    "db:setup": "prisma migrate dev && prisma db seed"
  },
  "keywords": [],
